#!/bin/sh
# soma — the single user-facing task command for the soma daemon.
#
# Dispatches `soma <verb> [args]` to soma_cli_main over the local Unix socket:
#
#   soma daemon [--socket P]              boot the daemon; blocks until `soma stop'
#   soma run <file|-> [--detach] [--socket P]
#   soma ask "<intent>" [--detach] [--socket P]
#   soma status <task-id> [--socket P]
#   soma cancel <task-id> [--socket P]
#   soma trace  <correlation-id> [--socket P]
#   soma stop   [--socket P]
#
# The wire is all-Lisp over $XDG_RUNTIME_DIR/soma.sock (else /tmp/soma-$USER.sock).
# This is the task client; the OTP node-control script is `bin/somad'. The two do
# not collide.
#
# It runs on the release's bundled ERTS (no separate Erlang install needed); in a
# dev tree it falls back to a system `erl'. Argv is passed after `-extra' so
# flag-shaped tokens (--detach, --socket) reach the program instead of `erl'.

set -e

here=$(cd "$(dirname "$0")" && pwd)
rel=$(cd "$here/.." && pwd)

# Prefer the release's bundled ERTS; fall back to a system `erl' for a dev tree.
erl=""
for d in "$rel"/erts-*/bin; do
    if [ -x "$d/erl" ]; then
        erl="$d/erl"
        break
    fi
done
[ -n "$erl" ] || erl="erl"

# Application code paths: the bundled/symlinked release libs, else a dev _build.
libs="$rel/lib"
[ -d "$libs" ] || libs="$rel/_build/default/lib"

run_soma() {
    # shellcheck disable=SC2086
    exec "$erl" -noshell -pa "$libs"/*/ebin \
        -run soma_cli_main main_argv -extra "$@"
}

# Auto-start: a client command that finds no live daemon brings one up itself, so
# there is no separate `soma daemon' ritual. Only client verbs auto-start;
# `daemon' / `stop' / `__ping' must not. A `--socket' override is carried to the
# probe and the auto-started daemon so all three resolve the same path. If two
# clients race, both launch a daemon but only one wins the kernel bind -- the
# loser's daemon_foreground returns and that BEAM exits -- so a lost race is
# harmless.
case "${1:-}" in
    run|ask|status|cancel|trace)
        sock=""; prev=""
        for a in "$@"; do
            [ "$prev" = "--socket" ] && sock="$a"
            prev="$a"
        done
        [ -n "$sock" ] && sflag="--socket $sock" || sflag=""
        # shellcheck disable=SC2086
        if ! "$0" __ping $sflag >/dev/null 2>&1; then
            # shellcheck disable=SC2086
            nohup "$0" daemon $sflag >/dev/null 2>&1 &
            i=0
            while [ "$i" -lt 50 ]; do
                # shellcheck disable=SC2086
                "$0" __ping $sflag >/dev/null 2>&1 && break
                sleep 0.1
                i=$((i + 1))
            done
        fi
        ;;
esac

run_soma "$@"
