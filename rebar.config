%% Soma umbrella project configuration.
{erl_opts, [debug_info, warnings_as_errors]}.

{deps, []}.

{dialyzer, [
    {warnings, [unmatched_returns, error_handling]}
]}.

{profiles, [
    {test, [
        {erl_opts, [debug_info, nowarn_export_all]}
    ]},
    %% Self-contained release: bundle ERTS and copy apps (not dev symlinks) so the
    %% tarball runs on a machine without Erlang installed. The artifact is per
    %% host architecture — `rebar3 as prod tar` on macOS arm64 yields a macOS
    %% arm64 release; the Linux x86_64/arm64 artifacts come from building the same
    %% profile on those hosts (CI/containers), tracked separately.
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true}
        ]}
    ]}
]}.

{relx, [
    %% The relx release is named `somad' so its generated node-control script is
    %% `bin/somad' (console/foreground/daemon/stop/...). The user-facing task
    %% command `bin/soma' (run/ask/status/cancel/trace/stop/daemon over the Unix
    %% socket) is the overlaid wrapper below -- a single command that does not
    %% collide with the node-control verbs.
    {release, {somad, "0.1.0"}, [
        soma_event_store,
        soma_tools,
        soma_runtime,
        soma_actor,
        sasl
    ]},
    {dev_mode, true},
    {include_erts, false},
    {extended_start_script, true},
    {overlay, [{copy, "scripts/soma", "bin/soma"}]}
]}.

{shell, [
    {apps, [soma_runtime]}
]}.
